{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canton-collateral-control-plane.dev/reports/substitution-report.schema.json",
  "title": "Substitution Report v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportType",
    "reportVersion",
    "substitutionReportId",
    "generatedAt",
    "overallStatus",
    "demo",
    "artifacts",
    "scenarios",
    "timeline",
    "invariantChecks"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "reportType": {
      "const": "SubstitutionReport"
    },
    "reportVersion": {
      "const": "0.1.0"
    },
    "substitutionReportId": {
      "type": "string",
      "pattern": "^srr-[0-9a-f]{16}$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "overallStatus": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "demo": {
      "$ref": "#/$defs/demo"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/timelineEntry"
      }
    },
    "invariantChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/invariantCheck"
      }
    }
  },
  "$defs": {
    "pathString": {
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "demo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "demoId",
        "demoVersion",
        "runtimeMode",
        "command",
        "manifestPath",
        "outputDirectory",
        "primaryOptimizationArtifact",
        "scenarioCount",
        "positiveScenarioCount",
        "negativeScenarioCount"
      ],
      "properties": {
        "demoId": {
          "$ref": "#/$defs/identifier"
        },
        "demoVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "runtimeMode": {
          "type": "string",
          "enum": [
            "IDE_LEDGER",
            "QUICKSTART"
          ]
        },
        "command": {
          "type": "string",
          "enum": [
            "make demo-substitution",
            "make demo-substitution-quickstart"
          ]
        },
        "manifestPath": {
          "$ref": "#/$defs/pathString"
        },
        "outputDirectory": {
          "$ref": "#/$defs/pathString"
        },
        "primaryOptimizationArtifact": {
          "$ref": "#/$defs/pathString"
        },
        "scenarioCount": {
          "type": "integer",
          "minimum": 1
        },
        "positiveScenarioCount": {
          "type": "integer",
          "minimum": 1
        },
        "negativeScenarioCount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "substitutionReportPath",
        "markdownSummaryPath",
        "timelinePath"
      ],
      "properties": {
        "substitutionReportPath": {
          "$ref": "#/$defs/pathString"
        },
        "markdownSummaryPath": {
          "$ref": "#/$defs/pathString"
        },
        "timelinePath": {
          "$ref": "#/$defs/pathString"
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "mode",
        "description",
        "result",
        "summary",
        "observedReasonCodes",
        "expectedReasonCodes",
        "policyEvaluationReportPath",
        "optimizationReportPath",
        "workflowInputPath",
        "workflowResultPath",
        "quickstartSeedReceiptPath",
        "adapterExecutionReportPath",
        "adapterStatusPath",
        "workflowRuntime",
        "policyDecision",
        "optimizationStatus",
        "recommendedAction",
        "currentPostedLotIds",
        "replacementLotIds",
        "blockedPhase",
        "adapterOutcome",
        "atomicityEvidence",
        "workflow"
      ],
      "properties": {
        "scenarioId": {
          "$ref": "#/$defs/identifier"
        },
        "mode": {
          "type": "string",
          "enum": [
            "POSITIVE",
            "NEGATIVE"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": [
            "SUCCESS",
            "EXPECTED_FAILURE"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "observedReasonCodes": {
          "$ref": "#/$defs/stringArray"
        },
        "expectedReasonCodes": {
          "$ref": "#/$defs/stringArray"
        },
        "policyEvaluationReportPath": {
          "$ref": "#/$defs/pathString"
        },
        "optimizationReportPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflowInputPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflowResultPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "quickstartSeedReceiptPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "adapterExecutionReportPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "adapterStatusPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflowRuntime": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "IDE_LEDGER",
            "QUICKSTART",
            null
          ]
        },
        "policyDecision": {
          "type": "string",
          "enum": [
            "ACCEPT",
            "REJECT",
            "ESCALATE",
            "REVIEW"
          ]
        },
        "optimizationStatus": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "OPTIMAL",
            "NO_SOLUTION",
            null
          ]
        },
        "recommendedAction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "POST_NEW_SET",
            "SUBSTITUTE",
            "KEEP_CURRENT_POSTED_SET",
            "NO_SOLUTION",
            null
          ]
        },
        "currentPostedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "replacementLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "blockedPhase": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "POLICY_EVALUATION",
            "OPTIMIZATION",
            "WORKFLOW",
            "ADAPTER",
            null
          ]
        },
        "adapterOutcome": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "EXECUTED",
            "BLOCKED",
            "NOT_REQUESTED",
            null
          ]
        },
        "atomicityEvidence": {
          "type": [
            "object",
            "null"
          ],
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/atomicityEvidence"
            }
          ]
        },
        "workflow": {
          "type": [
            "object",
            "null"
          ],
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/workflowResult"
            }
          ]
        }
      }
    },
    "workflowStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "phase",
        "actor",
        "state",
        "detail"
      ],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowExecutionReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportId",
        "workflowType",
        "outcome",
        "summary",
        "eventIds",
        "eventStates"
      ],
      "properties": {
        "reportId": {
          "$ref": "#/$defs/identifier"
        },
        "workflowType": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "eventIds": {
          "$ref": "#/$defs/stringArray"
        },
        "eventStates": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "controlCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkId",
        "status",
        "detail"
      ],
      "properties": {
        "checkId": {
          "$ref": "#/$defs/identifier"
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "atomicityEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proofStatus",
        "incumbentEncumberedLotIds",
        "approvedReplacementLotIds",
        "adapterActionReleaseLotIds",
        "adapterActionReplacementLotIds",
        "finalReleasedLotIds",
        "finalActiveEncumberedLotIds",
        "providerVisibleCurrentHoldingLotIds",
        "providerVisibleReplacementHoldingLotIds",
        "providerVisibleAdapterReceiptCount",
        "note"
      ],
      "properties": {
        "proofStatus": {
          "type": "string",
          "enum": [
            "ATOMICALLY_COMMITTED",
            "BLOCKED_NO_SIDE_EFFECTS",
            "IDE_LEDGER_WORKFLOW_ONLY"
          ]
        },
        "incumbentEncumberedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "approvedReplacementLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "adapterActionReleaseLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "adapterActionReplacementLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "finalReleasedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "finalActiveEncumberedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "providerVisibleCurrentHoldingLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "providerVisibleReplacementHoldingLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "providerVisibleAdapterReceiptCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenarioId",
        "obligationId",
        "substitutionState",
        "securedPartyApproval",
        "custodianApproval",
        "currentEncumberedLotIds",
        "releasedLotIds",
        "replacementLotIds",
        "activeEncumberedLotIds",
        "atomicityOutcome",
        "executionReportCount",
        "executionReports",
        "controlChecks",
        "steps"
      ],
      "properties": {
        "scenarioId": {
          "$ref": "#/$defs/identifier"
        },
        "obligationId": {
          "$ref": "#/$defs/identifier"
        },
        "correlationId": {
          "type": "string"
        },
        "workflowGate": {
          "type": "string"
        },
        "substitutionState": {
          "type": "string",
          "minLength": 1
        },
        "securedPartyApproval": {
          "type": "string",
          "minLength": 1
        },
        "custodianApproval": {
          "type": "string",
          "minLength": 1
        },
        "settlementInstructionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "settlementInstructionState": {
          "type": [
            "string",
            "null"
          ]
        },
        "currentEncumberedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "releasedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "replacementLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "activeEncumberedLotIds": {
          "$ref": "#/$defs/stringArray"
        },
        "atomicityOutcome": {
          "type": "string",
          "enum": [
            "COMMITTED_ATOMICALLY",
            "BLOCKED_ATOMICALLY",
            "PENDING_ATOMIC_SETTLEMENT"
          ]
        },
        "executionReportCount": {
          "type": "integer",
          "minimum": 0
        },
        "executionReports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflowExecutionReport"
          }
        },
        "controlChecks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/controlCheck"
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/workflowStep"
          }
        }
      }
    },
    "timelineEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "scenarioSequence",
        "scenarioId",
        "phase",
        "status",
        "startedAt",
        "finishedAt",
        "artifactPath",
        "detail"
      ],
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "scenarioSequence": {
          "type": "integer",
          "minimum": 1
        },
        "scenarioId": {
          "$ref": "#/$defs/identifier"
        },
        "phase": {
          "type": "string",
          "enum": [
            "POLICY_EVALUATION",
            "OPTIMIZATION",
            "QUICKSTART_SEED",
            "WORKFLOW",
            "ADAPTER"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "COMPLETED",
            "SKIPPED"
          ]
        },
        "startedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "finishedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "artifactPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "invariantCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invariantId",
        "status",
        "evidence",
        "note"
      ],
      "properties": {
        "invariantId": {
          "$ref": "#/$defs/identifier"
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pathString"
          }
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
